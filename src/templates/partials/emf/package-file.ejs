<%- header %>

<%
const ECORE_NS_URI = 'http://www.eclipse.org/emf/2002/Ecore';

// Helper: check if a classifier belongs to the current package
function isLocalClassifier(classifier) {
  const pkg = getEPackage(classifier);
  if (pkg) {
    const pkgNsURI = pkg.getNsURI?.() ?? null;
    return pkgNsURI === nsURI;
  }
  // For proxies, check the proxy URI
  if (typeof classifier.eIsProxy === 'function' && classifier.eIsProxy() && typeof classifier.eProxyURI === 'function') {
    const proxyURI = classifier.eProxyURI()?.toString() ?? '';
    return !proxyURI.startsWith('http://') && !proxyURI.startsWith('https://');
  }
  return true; // assume local if unknown
}

// Helper: check if a classifier is from the Ecore metamodel
function isEcoreClassifier(classifier) {
  const pkg = getEPackage(classifier);
  if (pkg) {
    const pkgNsURI = pkg.getNsURI?.() ?? null;
    return pkgNsURI === ECORE_NS_URI;
  }
  // For proxies, check the proxy URI
  if (typeof classifier.eIsProxy === 'function' && classifier.eIsProxy() && typeof classifier.eProxyURI === 'function') {
    const proxyURI = classifier.eProxyURI()?.toString() ?? '';
    return proxyURI.startsWith(ECORE_NS_URI);
  }
  return false;
}

// Helper: generate the right expression for a type reference
function typeRefExpr(classifier) {
  const typeName = getName(classifier);
  if (isLocalClassifier(classifier)) {
    const typeUpperName = typeName.replace(/([A-Z])/g, '_$1').toUpperCase().replace(/^_/, '');
    return packageName + 'Package.Literals.' + typeUpperName;
  }
  if (isEcoreClassifier(classifier)) {
    return "getEcorePackage().getEClassifier('" + typeName + "')!";
  }
  // Fallback for other external packages
  return "getEcorePackage().getEClassifier('" + typeName + "')!";
}

// Pre-scan: check if any cross-package Ecore references exist
let needsEcoreImport = false;
for (const genClass of genClasses) {
  const eClass = genClass.ecoreClass;
  for (const superType of getESuperTypes(eClass)) {
    if (!isLocalClassifier(superType)) { needsEcoreImport = true; break; }
  }
  if (needsEcoreImport) break;
  for (const genFeature of genClass.genFeatures) {
    const eType = getEType(genFeature.ecoreFeature);
    if (eType && typeMapper.isReference(genFeature.ecoreFeature) && !isLocalClassifier(eType)) {
      needsEcoreImport = true; break;
    }
  }
  if (needsEcoreImport) break;
}
-%>
<% if (needsEcoreImport) { -%>
import { BasicEPackage, BasicEClass, BasicEAttribute, BasicEReference, getEcorePackage } from '@emfts/core';
<% } else { -%>
import { BasicEPackage, BasicEClass, BasicEAttribute, BasicEReference } from '@emfts/core';
<% } -%>
import type { EClass, EAttribute, EReference, EEnum } from '@emfts/core';

/**
 * <%- packageName %> Package
 * @generated
 */
export class <%- packageName %>Package extends BasicEPackage {
  static readonly eNAME = '<%- getName(ePackage) %>';
  static readonly eNS_URI = '<%- nsURI %>';
  static readonly eNS_PREFIX = '<%- nsPrefix %>';

  // Singleton instance
  private static _instance: <%- packageName %>Package;

  static get eINSTANCE(): <%- packageName %>Package {
    if (!this._instance) {
      this._instance = new <%- packageName %>Package();
      this._instance.init();
    }
    return this._instance;
  }

  /**
   * Literals for quick access to metaclasses and features
   */
  static readonly Literals = {
<% for (const cls of classLiterals) { -%>
    <%- cls.upperName %>: null as unknown as EClass,
<% for (const feat of cls.features) { -%>
    <%- cls.upperName %>__<%- feat.upperName %>: null as unknown as EAttribute | EReference,
<% } -%>
<% } -%>
  };

  private constructor() {
    super();
    this.setName(<%- packageName %>Package.eNAME);
    this.setNsURI(<%- packageName %>Package.eNS_URI);
    this.setNsPrefix(<%- packageName %>Package.eNS_PREFIX);
  }

  /**
   * Initialize package contents
   */
  private init(): void {
<% for (const genClass of genClasses) {
  const eClass = genClass.ecoreClass;
  const className = getName(eClass);
  const upperName = className.replace(/([A-Z])/g, '_$1').toUpperCase().replace(/^_/, '');
-%>
    // Create <%- className %> class
    const <%- uncapitalize(className) %>Class = new BasicEClass();
    <%- uncapitalize(className) %>Class.setName('<%- className %>');
    <%- uncapitalize(className) %>Class.setAbstract(<%- checkIsAbstract(eClass) %>);
    <%- uncapitalize(className) %>Class.setInterface(<%- checkIsInterface(eClass) %>);
    this.getEClassifiers().push(<%- uncapitalize(className) %>Class);
    <%- uncapitalize(className) %>Class.setEPackage(this);
    <%- packageName %>Package.Literals.<%- upperName %> = <%- uncapitalize(className) %>Class;

<% let featureIndex = 0;
   for (const genFeature of genClass.genFeatures) {
     const feature = genFeature.ecoreFeature;
     const featureName = getName(feature);
     const featureUpperName = featureName.replace(/([A-Z])/g, '_$1').toUpperCase().replace(/^_/, '');
     const isRef = typeMapper.isReference(feature);
-%>
    // Create <%- featureName %> feature
<% if (isRef) { -%>
    const <%- uncapitalize(className) %>_<%- featureName %> = new BasicEReference();
    <%- uncapitalize(className) %>_<%- featureName %>.setContainment(<%- isContainment(feature) %>);
<% } else { -%>
    const <%- uncapitalize(className) %>_<%- featureName %> = new BasicEAttribute();
<% } -%>
    <%- uncapitalize(className) %>_<%- featureName %>.setName('<%- featureName %>');
    <%- uncapitalize(className) %>_<%- featureName %>.setLowerBound(<%- getLowerBound(feature) %>);
    <%- uncapitalize(className) %>_<%- featureName %>.setUpperBound(<%- getUpperBound(feature) %>);
    <%- uncapitalize(className) %>Class.getEStructuralFeatures().push(<%- uncapitalize(className) %>_<%- featureName %>);
    <%- packageName %>Package.Literals.<%- upperName %>__<%- featureUpperName %> = <%- uncapitalize(className) %>_<%- featureName %>;

<% featureIndex++;
   } -%>
<% } -%>
<%# TODO: Enum package metadata initialization - requires BasicEEnum implementation in emfts -%>

    // ============================================
    // Set ESuperTypes (must be done after all classes are created)
    // ============================================
<% for (const genClass of genClasses) {
     const eClass = genClass.ecoreClass;
     const className = getName(eClass);
     const upperName = className.replace(/([A-Z])/g, '_$1').toUpperCase().replace(/^_/, '');
     const superTypes = getESuperTypes(eClass);
     for (const superType of superTypes) {
       const superTypeName = getName(superType);
       if (superTypeName) {
-%>
    (<%- packageName %>Package.Literals.<%- upperName %> as BasicEClass).getESuperTypes().push(<%- typeRefExpr(superType) %>);
<%       }
     }
   } -%>

    // ============================================
    // Set ETypes for EReferences (must be done after all classes are created)
    // ============================================
<% for (const genClass of genClasses) {
     const eClass = genClass.ecoreClass;
     const className = getName(eClass);
     const upperName = className.replace(/([A-Z])/g, '_$1').toUpperCase().replace(/^_/, '');
     for (const genFeature of genClass.genFeatures) {
       const feature = genFeature.ecoreFeature;
       const featureName = getName(feature);
       const featureUpperName = featureName.replace(/([A-Z])/g, '_$1').toUpperCase().replace(/^_/, '');
       const isRef = typeMapper.isReference(feature);
       if (isRef) {
         const eType = getEType(feature);
         if (eType) {
-%>
    (<%- packageName %>Package.Literals.<%- upperName %>__<%- featureUpperName %> as BasicEReference).setEType(<%- typeRefExpr(eType) %>);
<%       }
       }
     }
   } -%>

    // ============================================
    // Register XML name mappings from ExtendedMetaData annotations
    // ============================================
<% for (const genClass of genClasses) {
     const eClass = genClass.ecoreClass;
     const className = getName(eClass);
     const upperName = className.replace(/([A-Z])/g, '_$1').toUpperCase().replace(/^_/, '');
     for (const genFeature of genClass.genFeatures) {
       const feature = genFeature.ecoreFeature;
       const featureName = getName(feature);
       const xmlName = getExtendedMetaDataName(feature);
       if (xmlName && xmlName !== featureName) {
         const featureUpperName = featureName.replace(/([A-Z])/g, '_$1').toUpperCase().replace(/^_/, '');
-%>
    (<%- packageName %>Package.Literals.<%- upperName %> as BasicEClass).registerXmlName('<%- xmlName %>', <%- packageName %>Package.Literals.<%- upperName %>__<%- featureUpperName %>);
<%       }
     }
   } -%>
  }
}
