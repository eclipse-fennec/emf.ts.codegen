<%- header %>

<%# Generate imports for referenced types -%>
<%
const imports = importResolver.resolveImportsForClass(eClass, genPackage, 'decorator');
for (const imp of imports) {
  if (imp.typeName !== className && !imp.typeName.includes(',')) {
-%>
import { <%- imp.typeName %> } from '<%- imp.importPath %>';
<%
  }
}
-%>
import { Documentation, Attribute, ModelClass, Reference, Enum } from './ModelAnnotations';

@ModelClass({ type: '<%- nsURI %>#//<%- className %>' })
export <% if (isAbstract) { %>abstract <% } %>class <%- className %><%
if (typeParameters && typeParameters.length > 0) {
  const params = [];
  for (const tp of typeParameters) {
    params.push(tp.getName());
  }
%><<%- params.join(', ') %>><%
}
if (superTypes && superTypes.length > 0) {
  const superNames = [];
  for (const st of superTypes) {
    if (st.getName) {
      superNames.push(st.getName());
    }
  }
  if (superNames.length > 0) {
%> extends <%- superNames[0] %><%
  }
}
%> {
<% for (const genFeature of features) {
  const feature = genFeature.ecoreFeature;
  const featureName = feature.getName();
  const featureType = typeMapper.mapFeatureBaseType(feature);
  const fullType = typeMapper.mapFeature(feature);
  const defaultValue = typeMapper.getDefaultValue(feature);
  const isMany = feature.isMany();
  const isRef = typeMapper.isReference(feature);
  const isEnum = feature.getEType() && typeMapper.isEEnum(feature.getEType());

  // Check for documentation annotation
  let doc = null;
  if (feature.getEAnnotations) {
    for (const ann of feature.getEAnnotations()) {
      const annSource = typeof ann.getSource === 'function' ? ann.getSource() : ann.source;
      if (annSource === 'http://www.eclipse.org/emf/2002/GenModel') {
        const details = typeof ann.getDetails === 'function' ? ann.getDetails() : ann.details;
        if (details && details.get) {
          doc = details.get('documentation');
        }
      }
    }
  }
  if (doc) {
-%>
  @Documentation("<%- doc %>")
<%
  }
  if (isEnum) {
-%>
  @Enum('<%- featureType %>')
<%
  } else if (isRef) {
-%>
  @Reference('<%- featureType %>')
<%
  } else {
-%>
  @Attribute()
<%
  }
-%>
  <%- featureName %><% if (!isMany && defaultValue === null) { %>?<% } %>: <%- fullType %><% if (defaultValue !== null) { %> = <%- defaultValue %><% } %>;

<% } -%>
<% for (const genOp of operations) {
  const op = genOp.ecoreOperation;
  const opName = op.getName();
  const returnType = op.getEType() ? typeMapper.mapClassifier(op.getEType()) : 'void';
  const params = [];
  for (const param of op.getEParameters()) {
    const paramName = param.getName();
    const paramType = typeMapper.mapClassifier(param.getEType());
    params.push(`${paramName}: ${paramType}`);
  }
-%>
  <%- opName %>(<%- params.join(', ') %>): <%- returnType %> {
    throw new Error('<%- opName %> not implemented');
  }

<% } -%>
}
