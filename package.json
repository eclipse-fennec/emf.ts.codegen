{
  "name": "@emfts/codegen",
  "version": "0.0.1-next.1",
  "description": "TypeScript code generator for Ecore models using emfts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "emfts-codegen": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && cp -r src/templates dist/templates",
    "watch": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "start": "node dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "generate": "tsx src/cli/index.ts generate",
    "generate:example": "tsx src/cli/index.ts generate -m examples/model/library.ecore -c examples/model/library.genconfig.xmi -o examples/generated",
    "typecheck:example": "tsc -p examples/tsconfig.json"
  },
  "keywords": [
    "emf",
    "ecore",
    "codegen",
    "typescript",
    "generator"
  ],
  "author": "",
  "license": "EPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/eclipse-fennec/emf.ts.codegen"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "commander": "^12.0.0",
    "ejs": "^3.1.10",
    "@emfts/core": "^0.1.1-next.2",
    "sax": "^1.4.4"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "volta": {
    "node": "20.19.4"
  }
}
